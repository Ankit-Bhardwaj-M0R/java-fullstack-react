@RestControllerAdvice
public class GlobalExceptionHandler {
    
    @Autowired
    private MessageSource messageSource;
    
    @ExceptionHandler(ResourceNotFoundException.class)
    @ResponseStatus(HttpStatus.NOT_FOUND)
    public ErrorResponse handleNotFound(
        ResourceNotFoundException e,
        HttpServletRequest request
    ) {
        Locale locale = LocaleContextHolder.getLocale();
        
        String message = messageSource.getMessage(
            "error.goal.notfound",
            new Object[]{e.getResourceId()},
            locale
        );
        
        return new ErrorResponse(404, message, LocalDateTime.now());
    }
    
    @ExceptionHandler(MethodArgumentNotValidException.class)
    @ResponseStatus(HttpStatus.BAD_REQUEST)
    public ErrorResponse handleValidation(
        MethodArgumentNotValidException e,
        HttpServletRequest request
    ) {
        Locale locale = LocaleContextHolder.getLocale();
        ErrorResponse error = new ErrorResponse(400, "Validation failed", LocalDateTime.now());
        
        e.getBindingResult().getFieldErrors().forEach(fieldError -> {
            String message = messageSource.getMessage(
                "error.validation." + fieldError.getCode(),
                new Object[]{fieldError.getField()},
                fieldError.getDefaultMessage(),
                locale
            );
            error.addValidationError(fieldError.getField(), message);
        });
        
        return error;
    }
}
